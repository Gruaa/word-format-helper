<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui" onLoad="OnRibbonLoad">
  <ribbon>
    <tabs>
      <tab id="WordFormatHelperTab" label="格式助手">
        <group id="PresetGroup" label="预设方案">
          <button id="StandardReport" label="公文报告" size="large"
                  imageMso="FileNew" onAction="OnApplyPreset" tag="standard"
                  screentip="对全文应用公文报告格式（GB/T 9704-2012）"
                  supertip="按党政机关公文格式标准对全文进行格式化，包括页面、各级标题、正文、表格、标点等。"/>
          <button id="AuditReport" label="审计报告" size="large"
                  imageMso="ReviewAcceptChange" onAction="OnApplyPreset" tag="audit"
                  screentip="对全文应用审计报告格式"
                  supertip="按审计报告常用格式对全文进行格式化。"/>
          <button id="CustomFormat" label="自定义格式" size="large"
                  imageMso="FormatPainter" onAction="OnApplyPreset" tag="custom"
                  screentip="对全文应用自定义格式"
                  supertip="应用您在「格式设置」中保存的自定义格式方案。"/>
          <button id="FormatSettings" label="格式设置" size="large"
                  imageMso="PageSetupDialog" onAction="OnOpenSettings"
                  screentip="修改各预设方案的具体格式参数"
                  supertip="打开对话框，可视化修改公文报告、审计报告、自定义格式三种方案的具体格式参数。"/>
        </group>
        <group id="ParagraphGroup" label="段落级别">
          <box id="ParagraphCol1" boxStyle="vertical">
            <button id="Heading1" label="一级标题" size="normal"
                    onAction="OnApplyStyle" tag="h1"
                    screentip="将当前选区设为一级标题"/>
            <button id="Heading2" label="二级标题" size="normal"
                    onAction="OnApplyStyle" tag="h2"
                    screentip="将当前选区设为二级标题"/>
            <button id="Heading3" label="三级标题" size="normal"
                    onAction="OnApplyStyle" tag="h3"
                    screentip="将当前选区设为三级标题"/>
          </box>
          <box id="ParagraphCol2" boxStyle="vertical">
            <button id="Heading4" label="四级标题" size="normal"
                    onAction="OnApplyStyle" tag="h4"
                    screentip="将当前选区设为四级标题"/>
            <button id="BodyText" label="正文" size="normal"
                    onAction="OnApplyStyle" tag="body"
                    screentip="将当前选区设为正文"/>
          </box>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
